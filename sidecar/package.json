{
  "name": "ananke-godot-sidecar",
  "version": "0.2.0",
  "type": "module",
  "description": "Ananke physics sidecar for Godot 4",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "dev": "npm run build && node --watch dist/src/main.js",
    "test": "npm run build && node --test dist/test/smoke.test.js",
    "check": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@its-not-rocket-science/ananke": "^0.1.15"
  }
}
